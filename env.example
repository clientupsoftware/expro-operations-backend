# Railway provee esta variable automaticamente al crear el servicio de Postgres.
# En local, copia este archivo como .env y pega la Connection String que te da Railway.
DATABASE_URL=postgresql://usuario:password@host:puerto/nombre_db

# Clave secreta para firmar los tokens JWT. Genera una propia (cualquier string largo y random).
JWT_SECRET=cambia-esto-por-un-string-largo-y-random

# Puerto del servidor (Railway lo asigna solo via process.env.PORT, esto es fallback para local)
PORT=4000

# Umbral por defecto del semaforo de certificacion, en dias (tambien vive en la tabla settings)
CERT_SEMAPHORE_THRESHOLD_DAYS=30
